# =============================================================================
# Doris 数据库配置
# =============================================================================
DORIS_HOST=doris
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DATABASE=opsRobot
# 定时任务表（与 docs/datamodel 一致时可为 cronjobs / cron_runs；列名 jobid、logattributes、agentid 已由后端自动探测，也可用环境变量覆盖）
# DORIS_CRON_JOBS_TABLE=cronjobs
# DORIS_CRON_RUNS_TABLE=cron_runs
# CRON_RUNS_COL_JOB_ID=jobid
# CRON_JOBS_COL_LOG_ATTRIBUTES=logattributes
# CRON_RUNS_COL_LOG_ATTRIBUTES=logattributes
VITE_MOCK=true

# =============================================================================
# API 服务配置
# =============================================================================
PORT=8787

# =============================================================================
# 前端配置（Docker 环境中 API 地址）
# =============================================================================
VITE_API_URL=/api

# 时区设置
TIMEZONE=Asia/Shanghai
# =============================================================================
# 前端 Mock 模式（无需数据库，用于 UI 调试）
# 启用方式：npm run dev:mock 或设置下方变量为 true 后运行 npm run dev
# =============================================================================
# VITE_MOCK=true
